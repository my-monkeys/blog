---
export interface Props {
  src: string;
  poster?: string;
  caption?: string;
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  controls?: boolean;
  width?: number;
  height?: number;
}
const {
  src,
  poster,
  caption,
  autoplay = false,
  loop = false,
  muted = autoplay, // autoplay implies muted for browser policy
  controls = !autoplay,
  width,
  height,
} = Astro.props;
---

<figure class="video-figure">
  <video
    src={src}
    poster={poster}
    controls={controls}
    autoplay={autoplay}
    loop={loop}
    muted={muted}
    playsinline
    preload={poster ? 'none' : 'metadata'}
    width={width}
    height={height}
  ></video>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .video-figure {
    margin: 2em 0;
  }
  .video-figure video {
    width: 100%;
    height: auto;
    display: block;
    border: 2px solid var(--ink);
    background: var(--bg-elev);
  }
  .video-figure figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--ink-soft);
    text-align: center;
  }
</style>
