---
// Theme toggle: respects prefers-color-scheme on first visit, persists in localStorage.
---

<button id="theme-toggle" aria-label="Basculer le thème" title="Thème">
  <span class="theme-icon-light">☀</span>
  <span class="theme-icon-dark">☾</span>
</button>

<style>
  #theme-toggle {
    font-size: 1.1rem;
    padding: 0.25rem 0.5rem;
    border: 2px solid var(--ink);
    background: var(--bg);
    line-height: 1;
  }
  #theme-toggle:hover { background: var(--bg-elev); }
  .theme-icon-dark { display: none; }
  [data-theme='dark'] .theme-icon-dark { display: inline; }
  [data-theme='dark'] .theme-icon-light { display: none; }
</style>

<script is:inline data-astro-rerun>
  (function () {
    function resolveTheme() {
      const stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') return stored;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    // Initial paint: set on current <html> immediately to avoid FOUC.
    document.documentElement.setAttribute('data-theme', resolveTheme());

    // View Transitions: apply theme to the new document BEFORE the swap,
    // otherwise <html>'s data-theme is wiped (new doc has no attribute).
    document.addEventListener('astro:before-swap', (e) => {
      e.newDocument.documentElement.setAttribute('data-theme', resolveTheme());
    });

    // Click handler: re-attach on every page load (including soft nav).
    function bindToggle() {
      const btn = document.getElementById('theme-toggle');
      if (!btn || btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    }
    document.addEventListener('astro:page-load', bindToggle);
    if (document.readyState !== 'loading') bindToggle();
  })();
</script>
