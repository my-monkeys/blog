---
export interface Props {
  symptom: string;
  cause: string;
  fix: string;
}
const { symptom, cause, fix } = Astro.props;
---

<div class="mortem">
  <div class="mortem-cell">
    <div class="mortem-label">Symptôme</div>
    <p>{symptom}</p>
  </div>
  <div class="mortem-cell">
    <div class="mortem-label">Cause</div>
    <p>{cause}</p>
  </div>
  <div class="mortem-cell">
    <div class="mortem-label">Fix</div>
    <p>{fix}</p>
  </div>
</div>

<style>
  .mortem {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 2px solid var(--ink);
    margin: 2em 0;
  }
  .mortem-cell {
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 20%, transparent);
    background: var(--bg-elev);
    align-items: baseline;
  }
  .mortem-cell:last-child { border-bottom: 0; }
  .mortem-cell p { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.5; }
  .mortem-label {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    flex-shrink: 0;
    min-width: 5.5rem;
  }
</style>
