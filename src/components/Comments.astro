---
// Comments — Supabase-backed, two auth modes:
// 1. Anonymous: session_token (uuid) stored in localStorage → edit/delete own comments
// 2. SSO My-Monkey: shared Supabase cookie on .my-monkey.fr → edit/delete via user_id
---

<section class="comments" aria-label="Commentaires">
  <div class="comments-header">
    <h2 class="section-heading">Commentaires</h2>
    <div class="comment-auth" data-comment-auth hidden>
      <button type="button" class="comment-login-btn" data-login-btn hidden>Se connecter</button>
      <div class="comment-user" data-comment-user hidden>
        <span class="comment-user-name" data-user-name></span>
        <button type="button" class="comment-logout-btn" data-logout-btn>Déconnexion</button>
      </div>
    </div>
  </div>

  <div class="comment-form-card">
    <form class="comment-form" data-comment-form>
      <input
        type="text"
        name="author_name"
        placeholder="Ton nom"
        required
        maxlength="80"
        autocomplete="name"
        class="comment-input"
      />
      <textarea
        name="message"
        placeholder="Ton commentaire…"
        required
        maxlength="2000"
        rows="3"
        class="comment-textarea"
      ></textarea>
      <div class="comment-form-footer">
        <span class="comment-error" data-comment-error></span>
        <button type="submit" class="comment-submit">Envoyer</button>
      </div>
    </form>
  </div>

  <div class="comment-list" data-comment-list>
    <p class="comment-loading">Chargement…</p>
  </div>
</section>

<script>
  import { createBrowserClient } from '@supabase/ssr';

  const SUPABASE_URL = 'https://klliwmgdyuatstjvzzbb.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtsbGl3bWdkeXVhdHN0anZ6emJiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI4MDI4MTAsImV4cCI6MjA4ODM3ODgxMH0.6qmXdDdToqZvqvaOXm8d-0r5rK6a-QCad2o1IRZe0KM';
  const TABLE = 'blog_comments';
  const TOKEN_KEY = 'blog_comment_token';
  const NAME_KEY = 'blog_comment_name';

  const supabase = createBrowserClient(SUPABASE_URL, SUPABASE_KEY, {
    cookieOptions: {
      domain: '.my-monkey.fr',
      path: '/',
      sameSite: 'lax' as const,
      secure: location.protocol === 'https:',
    },
  });

  function getSlug() {
    return window.location.pathname.replace(/\/+$/, '').split('/').pop() || '';
  }

  function getSessionToken(): string {
    let token = localStorage.getItem(TOKEN_KEY);
    if (!token) {
      token = crypto.randomUUID();
      localStorage.setItem(TOKEN_KEY, token);
    }
    return token;
  }

  function escapeHTML(s: string) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function timeAgo(dateStr: string) {
    const diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
    if (diff < 60) return "à l'instant";
    if (diff < 3600) return Math.floor(diff / 60) + ' min';
    if (diff < 86400) return Math.floor(diff / 3600) + ' h';
    if (diff < 2592000) return Math.floor(diff / 86400) + ' j';
    return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  interface Comment {
    id: string;
    post_slug: string;
    author_name: string;
    message: string;
    session_token: string;
    user_id: string | null;
    created_at: string;
  }

  let currentUser: { id: string; name: string } | null = null;

  function canEdit(c: Comment): boolean {
    if (currentUser && c.user_id === currentUser.id) return true;
    if (c.session_token === getSessionToken()) return true;
    return false;
  }

  function renderComments(comments: Comment[], listEl: HTMLElement) {
    if (!comments.length) {
      listEl.innerHTML = '<p class="comment-empty">Aucun commentaire. Sois le premier.</p>';
      return;
    }
    listEl.innerHTML = comments.map((c) =>
      `<div class="comment" data-id="${c.id}">
        <div class="comment-header">
          <span class="comment-author">${escapeHTML(c.author_name)}${c.user_id ? ' <span class="comment-verified" title="Compte My-Monkey">✓</span>' : ''}</span>
          <span class="comment-date">${timeAgo(c.created_at)}</span>
          ${canEdit(c) ? `<div class="comment-actions">
            <button type="button" class="comment-action-btn" data-edit="${c.id}" title="Modifier">✎</button>
            <button type="button" class="comment-action-btn comment-action-delete" data-delete="${c.id}" title="Supprimer">✕</button>
          </div>` : ''}
        </div>
        <p class="comment-body">${escapeHTML(c.message)}</p>
      </div>`
    ).join('');

    for (const btn of listEl.querySelectorAll<HTMLButtonElement>('[data-edit]')) {
      btn.addEventListener('click', () => startEdit(btn.dataset.edit!, comments));
    }
    for (const btn of listEl.querySelectorAll<HTMLButtonElement>('[data-delete]')) {
      btn.addEventListener('click', () => deleteComment(btn.dataset.delete!));
    }
  }

  function startEdit(id: string, comments: Comment[]) {
    const c = comments.find((x) => x.id === id);
    if (!c) return;
    const el = document.querySelector<HTMLElement>(`.comment[data-id="${id}"]`);
    if (!el) return;
    const body = el.querySelector('.comment-body')!;
    body.innerHTML = `
      <textarea class="comment-edit-textarea" maxlength="2000"></textarea>
      <div class="comment-edit-actions">
        <button type="button" class="comment-submit comment-save-btn" data-save="${id}">Sauver</button>
        <button type="button" class="comment-cancel-btn" data-cancel="${id}">Annuler</button>
      </div>
    `;
    const textarea = body.querySelector('textarea')!;
    textarea.value = c.message;
    textarea.focus();
    body.querySelector<HTMLButtonElement>('[data-save]')!.addEventListener('click', () => saveEdit(id, textarea.value));
    body.querySelector<HTMLButtonElement>('[data-cancel]')!.addEventListener('click', () => loadComments());
  }

  async function saveEdit(id: string, message: string) {
    const trimmed = message.trim();
    if (!trimmed) return;
    const { error } = await supabase
      .from(TABLE)
      .update({ message: trimmed })
      .eq('id', id)
      .headers({ 'x-session-token': getSessionToken() });
    if (error) console.error('update failed:', error);
    loadComments();
  }

  async function deleteComment(id: string) {
    if (!confirm('Supprimer ce commentaire ?')) return;
    const { error } = await supabase
      .from(TABLE)
      .delete()
      .eq('id', id)
      .headers({ 'x-session-token': getSessionToken() });
    if (error) console.error('delete failed:', error);
    loadComments();
  }

  async function loadComments() {
    const listEl = document.querySelector<HTMLElement>('[data-comment-list]');
    if (!listEl) return;
    const { data, error } = await supabase
      .from(TABLE)
      .select('*')
      .eq('post_slug', getSlug())
      .order('created_at', { ascending: true });
    if (error) {
      listEl.innerHTML = '<p class="comment-empty">Impossible de charger les commentaires.</p>';
      return;
    }
    renderComments(data as Comment[], listEl);
  }

  async function updateAuthUI() {
    const authContainer = document.querySelector<HTMLElement>('[data-comment-auth]');
    const loginBtn = document.querySelector<HTMLElement>('[data-login-btn]');
    const userEl = document.querySelector<HTMLElement>('[data-comment-user]');
    const nameInput = document.querySelector<HTMLInputElement>('[name="author_name"]');
    const nameEl = document.querySelector<HTMLElement>('[data-user-name]');

    const { data: { user } } = await supabase.auth.getUser();

    if (user) {
      const name = user.user_metadata?.full_name || user.user_metadata?.name || user.email || 'Utilisateur';
      currentUser = { id: user.id, name };
      if (loginBtn) loginBtn.hidden = true;
      if (userEl) userEl.hidden = false;
      if (nameInput) { nameInput.value = name; nameInput.readOnly = true; }
      if (nameEl) nameEl.textContent = name;
    } else {
      currentUser = null;
      if (loginBtn) loginBtn.hidden = false;
      if (userEl) userEl.hidden = true;
      if (nameInput) {
        nameInput.readOnly = false;
        const saved = localStorage.getItem(NAME_KEY);
        if (saved) nameInput.value = saved;
      }
    }

    if (authContainer) authContainer.hidden = false;
  }

  function attachForm() {
    const form = document.querySelector<HTMLFormElement>('[data-comment-form]');
    if (!form || form.dataset.attached === '1') return;
    form.dataset.attached = '1';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = form.querySelector<HTMLElement>('[data-comment-error]')!;
      const btn = form.querySelector<HTMLButtonElement>('.comment-submit')!;
      const nameInput = form.querySelector<HTMLInputElement>('[name="author_name"]')!;
      const msgInput = form.querySelector<HTMLTextAreaElement>('[name="message"]')!;
      const name = nameInput.value.trim();
      const msg = msgInput.value.trim();
      if (!name || !msg) return;

      btn.disabled = true;
      btn.textContent = '…';
      errorEl.textContent = '';

      if (!currentUser) localStorage.setItem(NAME_KEY, name);

      const row: Record<string, unknown> = {
        post_slug: getSlug(),
        author_name: name,
        message: msg,
        session_token: getSessionToken(),
      };
      if (currentUser) row.user_id = currentUser.id;

      const { error } = await supabase.from(TABLE).insert(row);
      if (error) {
        errorEl.textContent = 'Erreur : ' + (error.message || 'réessaie.');
      } else {
        msgInput.value = '';
        loadComments();
      }
      btn.disabled = false;
      btn.textContent = 'Envoyer';
    });
  }

  function attachAuth() {
    const loginBtn = document.querySelector<HTMLButtonElement>('[data-login-btn]');
    const logoutBtn = document.querySelector<HTMLButtonElement>('[data-logout-btn]');

    loginBtn?.addEventListener('click', () => {
      const redirectTo = window.location.href;
      window.location.href = `https://auth.my-monkey.fr/login?redirect=${encodeURIComponent(redirectTo)}`;
    });

    logoutBtn?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      updateAuthUI();
      loadComments();
    });
  }

  async function init() {
    await updateAuthUI();
    loadComments();
    attachForm();
    attachAuth();
  }

  document.addEventListener('astro:page-load', init);
</script>

<style>
  .comments {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--ink);
  }

  .comments-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .comments .section-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0;
  }

  /* Auth row */
  .comment-auth {
    align-items: center;
    gap: 0.75rem;
  }
  .comment-auth:not([hidden]) { display: flex; }
  .comment-login-btn {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: 2px solid var(--ink);
    background: var(--bg);
    color: var(--ink);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .comment-login-btn:hover {
    background: var(--ink);
    color: var(--bg);
  }
  .comment-user {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    align-items: center;
    gap: 0.5rem;
  }
  .comment-user:not([hidden]) { display: flex; }
  .comment-user-name { font-weight: 600; }
  .comment-logout-btn {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .comment-logout-btn:hover { opacity: 1; }

  /* Form card */
  .comment-form-card {
    border: 2px solid var(--ink);
    background: var(--bg-elev);
    padding: 1.25rem;
    margin-bottom: 2rem;
  }
  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .comment-input,
  .comment-textarea,
  .comment-edit-textarea {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    padding: 0.6rem 0.75rem;
    border: 2px solid color-mix(in srgb, var(--ink) 40%, transparent);
    background: var(--bg);
    color: var(--ink);
    width: 100%;
    resize: vertical;
    transition: border-color 0.15s;
  }
  .comment-input:hover,
  .comment-textarea:hover { border-color: var(--ink); }
  .comment-input[readonly] {
    background: var(--bg-elev);
    color: var(--ink-soft);
    border-style: dashed;
    cursor: not-allowed;
  }
  .comment-input::placeholder,
  .comment-textarea::placeholder {
    color: var(--ink-soft);
    opacity: 0.5;
  }
  .comment-input:focus,
  .comment-textarea:focus,
  .comment-edit-textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .comment-edit-textarea {
    margin-bottom: 0.5rem;
    min-height: 4rem;
  }
  .comment-form-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
  }
  .comment-error {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--alert);
    margin-right: auto;
  }
  .comment-submit {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 1.5rem;
    border: 2px solid var(--ink);
    background: var(--ink);
    color: var(--bg);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, box-shadow 0.15s;
  }
  .comment-submit:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    box-shadow: 4px 4px 0 var(--ink);
  }
  .comment-submit:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
  }

  .comment-edit-actions {
    display: flex;
    gap: 0.5rem;
  }
  .comment-cancel-btn {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    border: 2px solid color-mix(in srgb, var(--ink) 40%, transparent);
    background: var(--bg);
    color: var(--ink);
    cursor: pointer;
  }
  .comment-cancel-btn:hover { border-color: var(--ink); }

  /* Comment list — :global because items are injected via innerHTML */
  :global(.comment-list) {
    display: flex;
    flex-direction: column;
  }
  :global(.comment-loading),
  :global(.comment-empty) {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
  }

  :global(.comment) {
    padding: 1.25rem;
    border: 2px solid color-mix(in srgb, var(--ink) 20%, transparent);
    background: var(--bg-elev);
    margin-bottom: 0.75rem;
    transition: border-color 0.15s;
  }
  :global(.comment:hover) { border-color: color-mix(in srgb, var(--ink) 40%, transparent); }
  :global(.comment:last-child) { margin-bottom: 0; }
  :global(.comment-header) {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  :global(.comment-author) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }
  :global(.comment-verified) {
    color: var(--accent);
    font-size: 0.6875rem;
    font-weight: 700;
  }
  :global(.comment-date) {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  :global(.comment-actions) {
    margin-left: auto;
    display: flex;
    gap: 0.35rem;
  }
  :global(.comment-action-btn) {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border: 2px solid color-mix(in srgb, var(--ink) 20%, transparent);
    background: var(--bg);
    color: var(--ink-soft);
    cursor: pointer;
    line-height: 1;
    transition: all 0.15s;
  }
  :global(.comment-action-btn:hover) {
    color: var(--ink);
    border-color: var(--ink);
    box-shadow: 2px 2px 0 var(--ink);
  }
  :global(.comment-action-delete:hover) {
    color: var(--alert);
    border-color: var(--alert);
    box-shadow: 2px 2px 0 var(--alert);
  }
  :global(.comment-body) {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
