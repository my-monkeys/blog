---
export interface Props {
  code: string;
  caption?: string;
}
const { code, caption } = Astro.props;
const trimmed = code.replace(/^\n+|\n+$/g, '');
---

<figure class="mermaid-figure">
  <div class="mermaid-wrapper">
    <pre class="mermaid">{trimmed}</pre>
    <button
      class="mermaid-expand"
      type="button"
      aria-label="Agrandir le diagramme"
      title="Agrandir"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M3 10V3h7M21 10V3h-7M3 14v7h7M21 14v7h-7" />
      </svg>
    </button>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  let mermaidPromise: Promise<typeof import('mermaid').default> | null = null;

  async function getMermaid() {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => m.default);
    }
    const mermaid = await mermaidPromise;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'neutral',
      themeVariables: {
        fontFamily: "'JetBrains Mono', ui-monospace, monospace",
        fontSize: '14px',
      },
      securityLevel: 'strict',
      flowchart: { curve: 'basis' },
    });
    return mermaid;
  }

  function ensureDialog(): HTMLDialogElement {
    let dlg = document.getElementById('mermaid-dialog') as HTMLDialogElement | null;
    if (dlg) return dlg;
    dlg = document.createElement('dialog');
    dlg.id = 'mermaid-dialog';
    dlg.className = 'mermaid-dialog';
    dlg.innerHTML = `
      <button class="mermaid-dialog-close" type="button" aria-label="Fermer">&times;</button>
      <div class="mermaid-dialog-content"></div>
    `;
    document.body.appendChild(dlg);
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg!.close();
    });
    dlg.querySelector('.mermaid-dialog-close')?.addEventListener('click', () => dlg!.close());
    return dlg;
  }

  function openInDialog(svgHTML: string) {
    const dlg = ensureDialog();
    const content = dlg.querySelector<HTMLElement>('.mermaid-dialog-content');
    if (!content) return;
    content.innerHTML = svgHTML;
    const svg = content.querySelector<SVGSVGElement>('svg');
    if (svg) {
      svg.style.maxWidth = 'none';
      svg.style.width = '100%';
      svg.style.height = 'auto';
    }
    document.body.style.overflow = 'hidden';
    dlg.showModal();
    dlg.addEventListener('close', () => { document.body.style.overflow = ''; }, { once: true });
  }

  async function renderAll() {
    const blocks = document.querySelectorAll<HTMLPreElement>(
      'pre.mermaid:not([data-rendered])',
    );
    if (blocks.length === 0) return;
    const mermaid = await getMermaid();
    let idx = 0;
    for (const block of blocks) {
      block.dataset.rendered = '1';
      const code = block.textContent ?? '';
      try {
        const id = `mermaid-${Date.now()}-${idx++}`;
        const { svg } = await mermaid.render(id, code);
        block.innerHTML = svg;
        block.classList.add('is-rendered');

        // Click anywhere on the rendered diagram opens the lightbox,
        // unless the user is currently selecting text.
        block.addEventListener('click', () => {
          if (window.getSelection()?.toString()) return;
          openInDialog(svg);
        });

        // Wire the corner "expand" button. stopPropagation so it
        // doesn't double-trigger via the parent click handler.
        const wrapper = block.closest('.mermaid-wrapper');
        const expandBtn = wrapper?.querySelector<HTMLButtonElement>('.mermaid-expand');
        if (expandBtn) {
          expandBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            openInDialog(svg);
          });
        }
      } catch (e) {
        console.error('[mermaid] render failed:', e);
        block.classList.add('is-failed');
      }
    }
  }

  document.addEventListener('astro:page-load', renderAll);
</script>

<style is:global>
  .mermaid-figure {
    margin: 2em 0;
  }
  .mermaid-figure figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--ink-soft);
    text-align: center;
  }
  .mermaid-wrapper {
    position: relative;
  }
  .mermaid-expand {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 1;
    font: inherit;
    line-height: 1;
  }
  .mermaid-wrapper:hover .mermaid-expand,
  .mermaid-wrapper:focus-within .mermaid-expand {
    opacity: 1;
  }
  .mermaid-expand:hover {
    background: var(--ink);
    color: var(--bg);
  }
  .mermaid-expand:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    opacity: 1;
  }

  pre.mermaid {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    margin: 0;
    padding: 1.5rem;
    border: 2px solid var(--ink);
    background: var(--bg-elev);
    white-space: pre;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink);
  }
  pre.mermaid.is-rendered {
    padding: 1.5rem;
    text-align: center;
    cursor: zoom-in;
  }
  pre.mermaid.is-rendered svg {
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }
  pre.mermaid.is-failed {
    border-color: var(--alert);
    color: var(--alert);
  }
  pre.mermaid.is-failed::before {
    content: '⚠ Mermaid render failed (voir console)';
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  /* Lightbox dialog */
  .mermaid-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(96vw, 1400px);
    max-width: 96vw;
    height: 92vh;
    max-height: 92vh;
    padding: 0;
    border: 3px solid var(--ink);
    background: var(--bg);
    color: var(--ink);
    box-shadow: var(--shadow-hard);
  }
  .mermaid-dialog::backdrop {
    background: rgba(0, 0, 0, 0.75);
  }
  .mermaid-dialog-content {
    width: 100%;
    height: 100%;
    overflow: auto;
    padding: 2.5rem;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mermaid-dialog-close {
    position: absolute;
    top: 0;
    right: 0;
    width: 44px;
    height: 44px;
    font-size: 1.75rem;
    font-family: var(--font-display);
    line-height: 1;
    background: var(--bg);
    color: var(--ink);
    border: 0;
    border-left: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    cursor: pointer;
    z-index: 2;
  }
  .mermaid-dialog-close:hover {
    background: var(--ink);
    color: var(--bg);
  }
</style>
