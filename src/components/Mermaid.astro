---
export interface Props {
  code: string;
  caption?: string;
}
const { code, caption } = Astro.props;
const trimmed = code.replace(/^\n+|\n+$/g, '');
---

<figure class="mermaid-figure">
  <pre class="mermaid">{trimmed}</pre>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  // Lazy-loaded mermaid instance, shared across the page.
  let mermaidPromise: Promise<typeof import('mermaid').default> | null = null;

  async function getMermaid() {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => m.default);
    }
    const mermaid = await mermaidPromise;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'neutral',
      themeVariables: {
        fontFamily: "'JetBrains Mono', ui-monospace, monospace",
        fontSize: '14px',
      },
      securityLevel: 'strict',
      flowchart: { curve: 'basis' },
    });
    return mermaid;
  }

  async function renderAll() {
    const blocks = document.querySelectorAll<HTMLPreElement>(
      'pre.mermaid:not([data-rendered])',
    );
    if (blocks.length === 0) return;
    const mermaid = await getMermaid();
    let idx = 0;
    for (const block of blocks) {
      block.dataset.rendered = '1';
      const code = block.textContent ?? '';
      try {
        const id = `mermaid-${Date.now()}-${idx++}`;
        const { svg } = await mermaid.render(id, code);
        block.innerHTML = svg;
        block.classList.add('is-rendered');
      } catch (e) {
        console.error('[mermaid] render failed:', e);
        block.classList.add('is-failed');
      }
    }
  }

  document.addEventListener('astro:page-load', renderAll);
</script>

<style is:global>
  .mermaid-figure {
    margin: 2em 0;
  }
  .mermaid-figure figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--ink-soft);
    text-align: center;
  }
  pre.mermaid {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    margin: 0;
    padding: 1.5rem;
    border: 2px solid var(--ink);
    background: var(--bg-elev);
    white-space: pre;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink);
  }
  pre.mermaid.is-rendered {
    padding: 1.5rem;
    text-align: center;
  }
  pre.mermaid.is-rendered svg {
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }
  pre.mermaid.is-failed {
    border-color: var(--alert);
    color: var(--alert);
  }
  pre.mermaid.is-failed::before {
    content: '⚠ Mermaid render failed (voir console)';
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
</style>
