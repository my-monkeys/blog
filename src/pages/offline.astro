---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Hors ligne — Blog My-Monkey" description="Page hors ligne." noIndex>
  <section class="offline">
    <p class="meta">Hors ligne</p>
    <h1 class="post-title">Pas de réseau</h1>
    <div class="prose offline-body">
      <p>Cette page n'est pas encore dans ton cache, et t'as l'air d'être déconnecté.</p>
      <p>Reconnecte-toi pour la voir, ou retourne à une page déjà visitée :</p>
      <p>
        <a href="/">← Home</a> &nbsp;·&nbsp;
        <a href="/now/">Now</a> &nbsp;·&nbsp;
        <a href="/about/">About</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .offline { padding: 3rem 0 6rem; }
  .offline .meta { margin-bottom: 0.5rem; }
  .offline .post-title { margin-bottom: 1.5rem; }
  .offline-body { margin-top: 1.5rem; }
</style>
