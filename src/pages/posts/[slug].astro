---
import { getCollection } from 'astro:content';
import PostLayout from '@/layouts/PostLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('posts', ({ data }) => {
    if (import.meta.env.PROD && data.draft) return false;
    return true;
  });
  // Pages are generated only for non-link posts, but we still pass the
  // full `all` array to PostLayout so prev/next/related can consider
  // every published post.
  const renderable = all.filter((p) => p.data.type !== 'link');
  return renderable.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: all },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
---

<PostLayout post={post} headings={headings} allPosts={allPosts}>
  <Content />
</PostLayout>
